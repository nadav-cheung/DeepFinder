<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened Runtime entitlements for the DeepFinder daemon.

  The daemon runs outside the macOS sandbox because it requires Full Disk
  Access to index the entire filesystem. Sandbox entitlements are NOT
  applicable here — they would prevent the daemon from scanning arbitrary
  paths and would conflict with the Full Disk Access TCC entitlement.

  Swift binaries linked against the Swift runtime dylibs shipped in the
  bundle need disable-library-validation because those libraries are not
  signed by the same Developer ID certificate as the main executable.

  Signed with:
    codesign --deep --force --options runtime \
      --entitlements packaging/entitlements/deepfinder-daemon.plist \
      --sign "Developer ID Application" \
      .build/release/deepfinder-daemon
-->
<plist version="1.0">
<dict>
    <!--
      Allow loading of unsigned or third-party dynamic libraries.
      Required for Swift runtime libraries bundled alongside the binary,
      which are not code-signed by the same Developer ID certificate.
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
